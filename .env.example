# Session signing secret (any long random string)
SESSION_SECRET=your_secret_here

# Port the server listens on
PORT=5000

# Firebase service-account credentials.
# Option A (recommended for Render/hosting): paste the entire service-account
# JSON as a single line here.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Option B (local dev): path to the service-account JSON file instead.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
